/*
Jukeboxd DB Models
Database models to capture existing relations and entities that  
exist in the Jukeboxd application. 
*/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id        String   @id @default(uuid())  // Changed from auto() / @db.ObjectId
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  reviews   Review[]
}

model Album {
  id        String   @id @default(uuid())
  title     String
  year      Int
  artistId  String                         // Removed @db.ObjectId
  artist    Artist   @relation(fields: [artistId], references: [id])
  songs     Song[]
}

model Song {
  id        String   @id @default(uuid())
  title     String
  length    Int      
  albumId   String                         // Removed @db.ObjectId
  album     Album    @relation(fields: [albumId], references: [id])
}

model Artist {
  id        String   @id @default(uuid())
  name      String
  albums    Album[]
}

model Review {
  id        String   @id @default(uuid())  // Changed field 59 to string UUID if preferred
  userId    String                         // Removed @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
}
